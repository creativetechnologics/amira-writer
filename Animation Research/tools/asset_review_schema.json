{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://amirawriter.local/schemas/asset_review.schema.json",
  "title": "AssetReviewResult",
  "type": "object",
  "additionalProperties": false,
  "required": ["asset_id", "character_name", "asset_role", "expected_angle", "expected_costume", "overall_decision", "overall_confidence", "issues", "edit_recommendation"],
  "properties": {
    "asset_id": {"type": "string"},
    "character_name": {"type": "string"},
    "asset_role": {"type": "string"},
    "expected_angle": {"type": "string"},
    "expected_costume": {"type": "string"},
    "expected_pose": {"type": ["string", "null"]},
    "overall_decision": {"type": "string", "enum": ["approve", "edit", "regenerate", "reject", "escalate"]},
    "overall_confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "issue_summary": {"type": "string"},
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["severity", "category", "message", "fix_strategy"],
        "properties": {
          "severity": {"type": "string", "enum": ["critical", "major", "minor", "info"]},
          "category": {"type": "string", "enum": ["identity", "angle", "costume", "pose", "anatomy", "composition", "cleanliness", "style", "renderability", "other"]},
          "message": {"type": "string"},
          "evidence": {"type": "string"},
          "fix_strategy": {"type": "string", "enum": ["none", "edit", "regenerate", "human_review"]},
          "edit_instruction": {"type": ["string", "null"]}
        }
      }
    },
    "edit_recommendation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["use_edit", "edit_prompt"],
      "properties": {
        "use_edit": {"type": "boolean"},
        "edit_prompt": {"type": "string"},
        "preserve_facts": {"type": "array", "items": {"type": "string"}},
        "change_facts": {"type": "array", "items": {"type": "string"}}
      }
    },
    "next_action": {"type": "string", "enum": ["none", "approve_and_store", "edit_and_recheck", "regenerate_and_recheck", "escalate_to_human"]},
    "notes": {"type": "string"}
  }
}
